---
// 树遍历演示
---

<div class="tree-traversal-demo">
  <div class="demo-header">
    <span class="badge">交互演示</span>
    <span class="title">树的遍历</span>
  </div>
  <div class="demo-content">
    <div class="traversal-tabs">
      <button data-trav="preorder" class="active">先序</button>
      <button data-trav="inorder">中序</button>
      <button data-trav="postorder">后序</button>
      <button data-trav="bfs">层序</button>
    </div>
    <canvas id="treeTravCanvas"></canvas>
    <div class="controls">
      <button class="btn primary" id="startTravBtn">▶ 开始</button>
      <button class="btn" id="stepTravBtn">下一步</button>
      <button class="btn danger" id="resetTravBtn">重置</button>
      <div class="speed">
        <label>速度:</label>
        <input type="range" id="travSpeed" min="200" max="1500" value="700">
      </div>
    </div>
    <div class="result">
      <span class="label">遍历序列：</span>
      <span class="sequence" id="travSequence">-</span>
    </div>
    <div class="legend">
      <span class="item"><span class="dot blue"></span> 未访问</span>
      <span class="item"><span class="dot yellow"></span> 正在访问</span>
      <span class="item"><span class="dot green"></span> 已访问</span>
    </div>
  </div>
</div>

<style>
  .tree-traversal-demo {
    background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%);
    border-radius: 12px;
    padding: 1rem;
    margin: 1rem 0;
    border: 2px solid #ec4899;
  }
  .tree-traversal-demo .demo-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 0.8rem;
  }
  .tree-traversal-demo .badge {
    background: #ec4899;
    color: white;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .tree-traversal-demo .title {
    font-weight: 600;
    color: #9d174d;
  }
  .tree-traversal-demo .demo-content {
    background: white;
    border-radius: 8px;
    padding: 12px;
  }
  .tree-traversal-demo .traversal-tabs {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin-bottom: 10px;
  }
  .tree-traversal-demo .traversal-tabs button {
    padding: 5px 14px;
    border: 2px solid #e5e7eb;
    border-radius: 6px;
    background: white;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .tree-traversal-demo .traversal-tabs button:hover {
    border-color: #ec4899;
    background: #fdf2f8;
  }
  .tree-traversal-demo .traversal-tabs button.active {
    border-color: #ec4899;
    background: #ec4899;
    color: white;
  }
  .tree-traversal-demo canvas {
    display: block;
    margin: 0 auto;
    background: #fafafa;
    border-radius: 6px;
  }
  .tree-traversal-demo .controls {
    display: flex;
    gap: 8px;
    justify-content: center;
    align-items: center;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .tree-traversal-demo .btn {
    padding: 6px 14px;
    border: none;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    background: #e5e7eb;
    color: #374151;
  }
  .tree-traversal-demo .btn.primary {
    background: #ec4899;
    color: white;
  }
  .tree-traversal-demo .btn.danger {
    background: #ef4444;
    color: white;
  }
  .tree-traversal-demo .speed {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.75rem;
  }
  .tree-traversal-demo .speed input {
    width: 70px;
  }
  .tree-traversal-demo .result {
    margin-top: 10px;
    padding: 10px;
    background: #fdf2f8;
    border-radius: 6px;
    font-size: 0.85rem;
    text-align: center;
  }
  .tree-traversal-demo .result .label {
    color: #9d174d;
    font-weight: 600;
  }
  .tree-traversal-demo .result .sequence {
    color: #374151;
    font-family: monospace;
  }
  .tree-traversal-demo .legend {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin-top: 8px;
    font-size: 0.75rem;
  }
  .tree-traversal-demo .legend .item {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .tree-traversal-demo .legend .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .tree-traversal-demo .legend .dot.blue { background: #3b82f6; }
  .tree-traversal-demo .legend .dot.yellow { background: #f59e0b; }
  .tree-traversal-demo .legend .dot.green { background: #10b981; }
</style>

<script>
  const canvas = document.getElementById('treeTravCanvas');
  const ctx = canvas.getContext('2d');
  canvas.width = 400;
  canvas.height = 180;

  const nodes = [
    { id: 0, x: 200, y: 30, label: 'A', left: 1, right: 2 },
    { id: 1, x: 100, y: 75, label: 'B', left: 3, right: 4 },
    { id: 2, x: 300, y: 75, label: 'C', left: 5, right: 6 },
    { id: 3, x: 50, y: 120, label: 'D', left: null, right: null },
    { id: 4, x: 130, y: 120, label: 'E', left: null, right: null },
    { id: 5, x: 250, y: 120, label: 'F', left: null, right: null },
    { id: 6, x: 350, y: 120, label: 'G', left: null, right: null },
  ];

  const edges = [[0,1], [0,2], [1,3], [1,4], [2,5], [2,6]];

  let visited = [];
  let order = [];
  let current = null;
  let generator = null;
  let autoPlay = false;
  let timer = null;
  let travType = 'preorder';

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (let [u, v] of edges) {
      ctx.beginPath();
      ctx.moveTo(nodes[u].x, nodes[u].y);
      ctx.lineTo(nodes[v].x, nodes[v].y);
      ctx.strokeStyle = visited[u] && visited[v] ? '#10b981' : '#e5e7eb';
      ctx.lineWidth = visited[u] && visited[v] ? 3 : 2;
      ctx.stroke();
    }

    for (let node of nodes) {
      ctx.beginPath();
      ctx.arc(node.x, node.y, 16, 0, 2 * Math.PI);

      let fill = '#3b82f6';
      if (visited[node.id]) fill = '#10b981';
      if (node.id === current) fill = '#f59e0b';

      ctx.fillStyle = fill;
      ctx.fill();
      ctx.strokeStyle = '#1f2937';
      ctx.lineWidth = 2;
      ctx.stroke();

      ctx.fillStyle = '#fff';
      ctx.font = 'bold 12px Arial';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(node.label, node.x, node.y);
    }
  }

  function* preorder(id) {
    if (id === null) return;
    yield id;
    yield* preorder(nodes[id].left);
    yield* preorder(nodes[id].right);
  }

  function* inorder(id) {
    if (id === null) return;
    yield* inorder(nodes[id].left);
    yield id;
    yield* inorder(nodes[id].right);
  }

  function* postorder(id) {
    if (id === null) return;
    yield* postorder(nodes[id].left);
    yield* postorder(nodes[id].right);
    yield id;
  }

  function* bfs() {
    const queue = [0];
    const seen = new Set();
    while (queue.length) {
      const id = queue.shift();
      if (seen.has(id)) continue;
      seen.add(id);
      yield id;
      if (nodes[id].left !== null) queue.push(nodes[id].left);
      if (nodes[id].right !== null) queue.push(nodes[id].right);
    }
  }

  function step() {
    if (!generator) return;
    const r = generator.next();
    if (r.done) {
      autoPlay = false;
      if (timer) clearTimeout(timer);
      return;
    }
    current = r.value;
    visited[current] = true;
    order.push(nodes[current].label);
    document.getElementById('travSequence').textContent = order.join(' → ');
    draw();

    if (autoPlay) {
      const speed = 1700 - document.getElementById('travSpeed').value;
      timer = setTimeout(step, speed);
    }
  }

  function startTraversal() {
    visited = new Array(nodes.length).fill(false);
    order = [];
    current = null;
    document.getElementById('travSequence').textContent = '-';

    switch (travType) {
      case 'preorder': generator = preorder(0); break;
      case 'inorder': generator = inorder(0); break;
      case 'postorder': generator = postorder(0); break;
      case 'bfs': generator = bfs(); break;
    }

    autoPlay = true;
    step();
  }

  document.getElementById('startTravBtn').addEventListener('click', startTraversal);

  document.getElementById('stepTravBtn').addEventListener('click', () => {
    if (!generator) startTraversal();
    else { autoPlay = false; if (timer) clearTimeout(timer); step(); }
  });

  document.getElementById('resetTravBtn').addEventListener('click', () => {
    autoPlay = false;
    if (timer) clearTimeout(timer);
    generator = null;
    visited = new Array(nodes.length).fill(false);
    order = [];
    current = null;
    document.getElementById('travSequence').textContent = '-';
    draw();
  });

  document.querySelectorAll('.tree-traversal-demo [data-trav]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tree-traversal-demo [data-trav]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      travType = btn.dataset.trav;
      document.getElementById('resetTravBtn').click();
    });
  });

  draw();
</script>