---
// 树的直径性质：中点重合
---

<div class="tree-diameter-mid-demo">
  <div class="demo-header">
    <span class="badge">交互演示</span>
    <span class="title">直径的中点重合</span>
  </div>
  <div class="demo-content">
    <canvas id="midCanvas"></canvas>
    <div class="info" id="midInfo">
      <p>当边权为正时，所有直径的中点必定重合。</p>
      <p>点击下方按钮查看不同直径。</p>
    </div>
    <div class="controls">
      <button class="btn" data-diameter="1">直径 1: H→I</button>
      <button class="btn" data-diameter="2">直径 2: H→F</button>
      <button class="btn" data-diameter="3">直径 3: E→I</button>
      <button class="btn primary" id="showAllBtn">显示全部</button>
    </div>
  </div>
</div>

<style>
  .tree-diameter-mid-demo {
    background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
    border-radius: 12px;
    padding: 1rem;
    margin: 1rem 0;
    border: 2px solid #22c55e;
  }
  .tree-diameter-mid-demo .demo-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 0.8rem;
  }
  .tree-diameter-mid-demo .badge {
    background: #22c55e;
    color: white;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .tree-diameter-mid-demo .title {
    font-weight: 600;
    color: #166534;
  }
  .tree-diameter-mid-demo .demo-content {
    background: white;
    border-radius: 8px;
    padding: 12px;
  }
  .tree-diameter-mid-demo canvas {
    display: block;
    margin: 0 auto;
    background: #fafafa;
    border-radius: 6px;
  }
  .tree-diameter-mid-demo .info {
    margin: 10px 0;
    padding: 10px;
    background: #f0fdf4;
    border-radius: 6px;
    font-size: 0.85rem;
    text-align: center;
  }
  .tree-diameter-mid-demo .info p {
    margin: 4px 0;
    color: #166534;
  }
  .tree-diameter-mid-demo .controls {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .tree-diameter-mid-demo .btn {
    padding: 6px 14px;
    border: 2px solid #e5e7eb;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    background: white;
    color: #374151;
  }
  .tree-diameter-mid-demo .btn:hover {
    border-color: #22c55e;
    background: #f0fdf4;
  }
  .tree-diameter-mid-demo .btn.active {
    border-color: #22c55e;
    background: #22c55e;
    color: white;
  }
  .tree-diameter-mid-demo .btn.primary {
    background: #22c55e;
    color: white;
    border-color: #22c55e;
  }
</style>

<script>
  const canvas = document.getElementById('midCanvas');
  const ctx = canvas.getContext('2d');
  canvas.width = 480;
  canvas.height = 240;

  // 树结构 - 设计有多条直径的树
  const nodes = [
    { id: 0, x: 240, y: 50, label: 'A' },   // 根
    { id: 1, x: 160, y: 110, label: 'B' },  // 左子
    { id: 2, x: 320, y: 110, label: 'C' },  // 右子
    { id: 3, x: 80, y: 170, label: 'D' },   // B的左子
    { id: 4, x: 180, y: 170, label: 'E' },  // B的右子
    { id: 5, x: 300, y: 170, label: 'F' },  // C的左子
    { id: 6, x: 400, y: 170, label: 'G' },  // C的右子
    { id: 7, x: 80, y: 230, label: 'H' },   // D的子 (直径端点1)
    { id: 8, x: 400, y: 230, label: 'I' },  // G的子 (直径端点2)
  ];

  const edges = [
    [0, 1], [0, 2], [1, 3], [1, 4], [2, 5], [2, 6], [3, 7], [6, 8]
  ];

  // 三条直径
  const diameters = {
    1: { path: [7, 3, 1, 0, 2, 6, 8], color: '#ef4444', label: 'H→I' },
    2: { path: [7, 3, 1, 0, 2, 5], color: '#3b82f6', label: 'H→F' },
    3: { path: [4, 1, 0, 2, 6, 8], color: '#8b5cf6', label: 'E→I' }
  };

  // 中点 (对于长度为6的路径，中点是第3个节点，即节点0)
  const midpoint = 0;

  let showDiameters = [];

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // 绘制边
    edges.forEach(([u, v]) => {
      ctx.beginPath();
      ctx.moveTo(nodes[u].x, nodes[u].y);
      ctx.lineTo(nodes[v].x, nodes[v].y);

      // 检查是否在某条直径上
      let inDiameter = false;
      for (let key of showDiameters) {
        const d = diameters[key];
        for (let i = 0; i < d.path.length - 1; i++) {
          if ((d.path[i] === u && d.path[i+1] === v) ||
              (d.path[i] === v && d.path[i+1] === u)) {
            ctx.strokeStyle = d.color;
            ctx.lineWidth = 4;
            inDiameter = true;
            break;
          }
        }
        if (inDiameter) break;
      }

      if (!inDiameter) {
        ctx.strokeStyle = '#e5e7eb';
        ctx.lineWidth = 2;
      }

      ctx.stroke();
    });

    // 绘制节点
    nodes.forEach(node => {
      // 检查是否在某条直径上
      let inDiameter = false;
      let colors = [];
      for (let key of showDiameters) {
        if (diameters[key].path.includes(node.id)) {
          colors.push(diameters[key].color);
          inDiameter = true;
        }
      }

      ctx.beginPath();
      ctx.arc(node.x, node.y, 18, 0, 2 * Math.PI);

      let fill = '#94a3b8';
      if (node.id === midpoint) {
        fill = '#f97316'; // 中点用橙色
      } else if (inDiameter && colors.length === 1) {
        fill = colors[0];
      } else if (inDiameter) {
        fill = '#22c55e'; // 多条直径交点
      }

      ctx.fillStyle = fill;
      ctx.fill();
      ctx.strokeStyle = '#1f2937';
      ctx.lineWidth = 2;
      ctx.stroke();

      ctx.fillStyle = '#fff';
      ctx.font = 'bold 12px Arial';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(node.label, node.x, node.y);

      // 中点标记
      if (node.id === midpoint) {
        ctx.fillStyle = '#f97316';
        ctx.font = 'bold 10px Arial';
        ctx.fillText('中点', node.x, node.y - 28);
      }
    });

    // 图例
    if (showDiameters.length > 0) {
      let y = 20;
      ctx.font = '11px Arial';
      ctx.textAlign = 'left';
      for (let key of showDiameters) {
        const d = diameters[key];
        ctx.fillStyle = d.color;
        ctx.fillRect(10, y - 8, 20, 3);
        ctx.fillStyle = '#374151';
        ctx.fillText(`直径 ${key}: ${d.label}`, 35, y);
        y += 18;
      }
    }
  }

  document.querySelectorAll('.tree-diameter-mid-demo [data-diameter]').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.diameter;

      if (showDiameters.includes(key)) {
        showDiameters = showDiameters.filter(k => k !== key);
        btn.classList.remove('active');
      } else {
        showDiameters.push(key);
        btn.classList.add('active');
      }

      draw();
    });
  });

  document.getElementById('showAllBtn').addEventListener('click', function() {
    if (showDiameters.length === 3) {
      showDiameters = [];
      document.querySelectorAll('.tree-diameter-mid-demo [data-diameter]').forEach(b => b.classList.remove('active'));
      this.textContent = '显示全部';
    } else {
      showDiameters = ['1', '2', '3'];
      document.querySelectorAll('.tree-diameter-mid-demo [data-diameter]').forEach(b => b.classList.add('active'));
      this.textContent = '隐藏全部';
    }
    draw();
  });

  draw();
</script>