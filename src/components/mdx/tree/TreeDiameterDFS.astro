---
// 树的直径演示：两次DFS方法
---

<div class="tree-diameter-dfs-demo">
  <div class="demo-header">
    <span class="badge">交互演示</span>
    <span class="title">两次 DFS 求直径</span>
  </div>
  <div class="demo-content">
    <canvas id="dfsCanvas"></canvas>
    <div class="steps">
      <div class="step" id="dfsStep1">
        <span class="num">1</span>
        <span class="text">从任意点出发 DFS</span>
      </div>
      <div class="step" id="dfsStep2">
        <span class="num">2</span>
        <span class="text">找到最远点 z</span>
      </div>
      <div class="step" id="dfsStep3">
        <span class="num">3</span>
        <span class="text">从 z 出发 DFS</span>
      </div>
      <div class="step" id="dfsStep4">
        <span class="num">4</span>
        <span class="text">找到最远点 z'</span>
      </div>
    </div>
    <div class="controls">
      <button class="btn primary" id="startDfsBtn">▶ 开始演示</button>
      <button class="btn" id="stepDfsBtn">下一步</button>
      <button class="btn danger" id="resetDfsBtn">重置</button>
    </div>
    <div class="result" id="dfsResult">
      <span class="label">直径：</span>
      <span class="value">-</span>
    </div>
  </div>
</div>

<style>
  .tree-diameter-dfs-demo {
    background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
    border-radius: 12px;
    padding: 1rem;
    margin: 1rem 0;
    border: 2px solid #6366f1;
  }
  .tree-diameter-dfs-demo .demo-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 0.8rem;
  }
  .tree-diameter-dfs-demo .badge {
    background: #6366f1;
    color: white;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .tree-diameter-dfs-demo .title {
    font-weight: 600;
    color: #3730a3;
  }
  .tree-diameter-dfs-demo .demo-content {
    background: white;
    border-radius: 8px;
    padding: 12px;
  }
  .tree-diameter-dfs-demo canvas {
    display: block;
    margin: 0 auto;
    background: #fafafa;
    border-radius: 6px;
  }
  .tree-diameter-dfs-demo .steps {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin: 12px 0;
    flex-wrap: wrap;
  }
  .tree-diameter-dfs-demo .step {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: #f1f5f9;
    border-radius: 20px;
    font-size: 0.75rem;
    border: 2px solid transparent;
    transition: all 0.3s;
  }
  .tree-diameter-dfs-demo .step.active {
    background: #eef2ff;
    border-color: #6366f1;
  }
  .tree-diameter-dfs-demo .step.done {
    background: #dcfce7;
    border-color: #22c55e;
  }
  .tree-diameter-dfs-demo .step .num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: #cbd5e1;
    border-radius: 50%;
    font-weight: 600;
    font-size: 0.7rem;
  }
  .tree-diameter-dfs-demo .step.active .num {
    background: #6366f1;
    color: white;
  }
  .tree-diameter-dfs-demo .step.done .num {
    background: #22c55e;
    color: white;
  }
  .tree-diameter-dfs-demo .controls {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .tree-diameter-dfs-demo .btn {
    padding: 6px 14px;
    border: none;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    background: #e5e7eb;
    color: #374151;
  }
  .tree-diameter-dfs-demo .btn.primary {
    background: #6366f1;
    color: white;
  }
  .tree-diameter-dfs-demo .btn.danger {
    background: #ef4444;
    color: white;
  }
  .tree-diameter-dfs-demo .result {
    margin-top: 10px;
    padding: 10px;
    background: #f0f9ff;
    border-radius: 6px;
    text-align: center;
    font-size: 0.9rem;
  }
  .tree-diameter-dfs-demo .result .label {
    color: #0369a1;
    font-weight: 600;
  }
  .tree-diameter-dfs-demo .result .value {
    color: #0c4a6e;
    font-family: monospace;
  }
</style>

<script>
  const canvas = document.getElementById('dfsCanvas');
  const ctx = canvas.getContext('2d');
  canvas.width = 480;
  canvas.height = 280;

  // 树结构
  const nodes = [
    { id: 0, x: 240, y: 50, label: 'A' },
    { id: 1, x: 120, y: 120, label: 'B' },
    { id: 2, x: 360, y: 120, label: 'C' },
    { id: 3, x: 60, y: 190, label: 'D' },
    { id: 4, x: 160, y: 190, label: 'E' },
    { id: 5, x: 300, y: 190, label: 'F' },
    { id: 6, x: 420, y: 190, label: 'G' },
    { id: 7, x: 60, y: 260, label: 'H' },
    { id: 8, x: 420, y: 260, label: 'I' },
  ];

  const edges = [
    [0, 1], [0, 2], [1, 3], [1, 4], [2, 5], [2, 6], [3, 7], [6, 8]
  ];

  const adj = {};
  nodes.forEach(n => adj[n.id] = []);
  edges.forEach(([u, v]) => {
    adj[u].push(v);
    adj[v].push(u);
  });

  let phase = 0; // 0: 初始, 1: 第一次DFS, 2: 找到z, 3: 第二次DFS, 4: 完成
  let startNode = 0;
  let farthestNode = null;
  let diameterEnd = null;
  let visitedNodes = [];
  let distance = {};
  let diameterPath = [];
  let animating = false;

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // 绘制边
    edges.forEach(([u, v]) => {
      const inPath = diameterPath.includes(u) && diameterPath.includes(v);
      ctx.beginPath();
      ctx.moveTo(nodes[u].x, nodes[u].y);
      ctx.lineTo(nodes[v].x, nodes[v].y);
      ctx.strokeStyle = inPath ? '#f97316' : '#e2e8f0';
      ctx.lineWidth = inPath ? 4 : 2;
      ctx.stroke();
    });

    // 绘制节点
    nodes.forEach(node => {
      ctx.beginPath();
      ctx.arc(node.x, node.y, 20, 0, 2 * Math.PI);

      let fill = '#94a3b8';
      if (visitedNodes.includes(node.id)) fill = '#a5b4fc';
      if (node.id === startNode && phase >= 1) fill = '#22c55e';
      if (node.id === farthestNode) fill = '#6366f1';
      if (node.id === diameterEnd) fill = '#ec4899';
      if (diameterPath.includes(node.id) && phase === 4) fill = '#f97316';

      ctx.fillStyle = fill;
      ctx.fill();
      ctx.strokeStyle = '#1f2937';
      ctx.lineWidth = 2;
      ctx.stroke();

      ctx.fillStyle = '#fff';
      ctx.font = 'bold 13px Arial';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(node.label, node.x, node.y);

      // 显示距离
      if (distance[node.id] !== undefined && phase > 0) {
        ctx.fillStyle = '#6b7280';
        ctx.font = '10px Arial';
        ctx.fillText(`d=${distance[node.id]}`, node.x, node.y + 30);
      }
    });

    // 说明文字
    ctx.fillStyle = '#374151';
    ctx.font = '12px Arial';
    ctx.textAlign = 'center';
    if (phase === 0) {
      ctx.fillText('准备开始：从节点 A 出发', canvas.width / 2, 20);
    } else if (phase === 1) {
      ctx.fillText(`第一次 DFS：从 ${nodes[startNode].label} 出发，寻找最远点`, canvas.width / 2, 20);
    } else if (phase === 2) {
      ctx.fillText(`找到最远点 ${nodes[farthestNode].label}！`, canvas.width / 2, 20);
    } else if (phase === 3) {
      ctx.fillText(`第二次 DFS：从 ${nodes[farthestNode].label} 出发`, canvas.width / 2, 20);
    } else if (phase === 4) {
      ctx.fillText(`直径：${nodes[farthestNode].label} → ${nodes[diameterEnd].label}，长度 = ${distance[diameterEnd]}`, canvas.width / 2, 20);
    }
  }

  function updateSteps() {
    document.querySelectorAll('.tree-diameter-dfs-demo .step').forEach((el, i) => {
      el.classList.remove('active', 'done');
      if (i < phase - 1) el.classList.add('done');
      else if (i === phase - 1 || (phase === 0 && i === 0)) el.classList.add('active');
    });
  }

  function dfs(start) {
    visitedNodes = [];
    distance = {};
    const stack = [[start, -1, 0]];

    while (stack.length > 0) {
      const [node, parent, dist] = stack.pop();
      if (visitedNodes.includes(node)) continue;

      visitedNodes.push(node);
      distance[node] = dist;

      for (let neighbor of adj[node]) {
        if (neighbor !== parent) {
          stack.push([neighbor, node, dist + 1]);
        }
      }
    }

    // 找最远点
    let maxDist = 0;
    let farthest = start;
    for (let [id, d] of Object.entries(distance)) {
      if (d > maxDist) {
        maxDist = d;
        farthest = parseInt(id);
      }
    }
    return farthest;
  }

  function findPath(start, end) {
    const queue = [[start, [start]]];
    const visited = new Set([start]);

    while (queue.length > 0) {
      const [node, path] = queue.shift();
      if (node === end) return path;

      for (let neighbor of adj[node]) {
        if (!visited.has(neighbor)) {
          visited.add(neighbor);
          queue.push([neighbor, [...path, neighbor]]);
        }
      }
    }
    return [];
  }

  function animateDFS(callback) {
    animating = true;
    let index = 0;
    const visitOrder = [...visitedNodes];

    function step() {
      if (index < visitOrder.length) {
        const tempVisited = visitOrder.slice(0, index + 1);
        visitedNodes = tempVisited;
        draw();
        index++;
        setTimeout(step, 150);
      } else {
        animating = false;
        if (callback) callback();
      }
    }
    step();
  }

  function runDFS1() {
    phase = 1;
    updateSteps();
    draw();

    dfs(startNode);

    animateDFS(() => {
      farthestNode = dfs(startNode);
      phase = 2;
      updateSteps();
      draw();
      document.getElementById('dfsResult').innerHTML = `
        <span class="label">第一次 DFS：</span>
        <span class="value">最远点 ${nodes[farthestNode].label}</span>
      `;
    });
  }

  function runDFS2() {
    phase = 3;
    updateSteps();

    dfs(farthestNode);

    animateDFS(() => {
      diameterEnd = dfs(farthestNode);
      diameterPath = findPath(farthestNode, diameterEnd);
      phase = 4;
      updateSteps();
      draw();
      document.getElementById('dfsResult').innerHTML = `
        <span class="label">直径：</span>
        <span class="value">${nodes[farthestNode].label} → ${nodes[diameterEnd].label}，长度 = ${distance[diameterEnd]}</span>
      `;
    });
  }

  document.getElementById('startDfsBtn').addEventListener('click', () => {
    if (phase === 0) {
      runDFS1();
    } else if (phase === 2) {
      runDFS2();
    }
  });

  document.getElementById('stepDfsBtn').addEventListener('click', () => {
    if (phase === 0) runDFS1();
    else if (phase === 2) runDFS2();
  });

  document.getElementById('resetDfsBtn').addEventListener('click', () => {
    phase = 0;
    startNode = 0;
    farthestNode = null;
    diameterEnd = null;
    visitedNodes = [];
    distance = {};
    diameterPath = [];
    updateSteps();
    document.getElementById('dfsResult').innerHTML = '<span class="label">直径：</span><span class="value">-</span>';
    draw();
  });

  draw();
</script>