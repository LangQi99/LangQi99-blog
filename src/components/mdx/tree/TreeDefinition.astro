---
// 树的定义演示：无根树 vs 有根树
---

<div class="tree-def-demo">
  <div class="demo-header">
    <span class="badge">交互演示</span>
    <span class="title">无根树 ⇄ 有根树</span>
  </div>
  <div class="demo-content">
    <canvas id="treeDefCanvas"></canvas>
    <div class="controls">
      <button class="btn" id="toggleRootModeBtn">选择根节点</button>
      <button class="btn primary" id="convertBtn">转换为有根树</button>
      <button class="btn danger" id="resetTreeBtn">重置</button>
    </div>
    <p class="hint" id="treeDefHint">点击"选择根节点"后，再点击树上任意节点作为根</p>
  </div>
</div>

<style>
  .tree-def-demo {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border-radius: 12px;
    padding: 1rem;
    margin: 1rem 0;
    border: 2px solid #f59e0b;
  }
  .tree-def-demo .demo-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 0.8rem;
  }
  .tree-def-demo .badge {
    background: #f59e0b;
    color: white;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .tree-def-demo .title {
    font-weight: 600;
    color: #92400e;
  }
  .tree-def-demo .demo-content {
    background: white;
    border-radius: 8px;
    padding: 12px;
  }
  .tree-def-demo canvas {
    display: block;
    margin: 0 auto;
    background: #fafafa;
    border-radius: 6px;
  }
  .tree-def-demo .controls {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .tree-def-demo .btn {
    padding: 6px 14px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    background: #e5e7eb;
    color: #374151;
    transition: all 0.2s;
  }
  .tree-def-demo .btn:hover {
    background: #d1d5db;
  }
  .tree-def-demo .btn.primary {
    background: #f97316;
    color: white;
  }
  .tree-def-demo .btn.primary:hover {
    background: #ea580c;
  }
  .tree-def-demo .btn.danger {
    background: #ef4444;
    color: white;
  }
  .tree-def-demo .btn.danger:hover {
    background: #dc2626;
  }
  .tree-def-demo .btn.active {
    background: #3b82f6;
    color: white;
  }
  .tree-def-demo .hint {
    text-align: center;
    font-size: 0.8rem;
    color: #6b7280;
    margin: 8px 0 0 0;
  }
</style>

<script>
  const canvas = document.getElementById('treeDefCanvas');
  const ctx = canvas.getContext('2d');
  canvas.width = 400;
  canvas.height = 220;

  let nodes = [
    { id: 0, x: 200, y: 35, label: 'A' },
    { id: 1, x: 100, y: 90, label: 'B' },
    { id: 2, x: 300, y: 90, label: 'C' },
    { id: 3, x: 50, y: 150, label: 'D' },
    { id: 4, x: 130, y: 150, label: 'E' },
    { id: 5, x: 250, y: 150, label: 'F' },
    { id: 6, x: 350, y: 150, label: 'G' },
    { id: 7, x: 50, y: 200, label: 'H' },
  ];

  let edges = [[0,1], [0,2], [1,3], [1,4], [2,5], [2,6], [3,7]];

  let selectedRoot = null;
  let isRooted = false;
  let selectMode = false;

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // 绘制边
    for (let [u, v] of edges) {
      ctx.beginPath();
      ctx.moveTo(nodes[u].x, nodes[u].y);
      ctx.lineTo(nodes[v].x, nodes[v].y);
      ctx.strokeStyle = isRooted ? '#10b981' : '#d1d5db';
      ctx.lineWidth = isRooted ? 3 : 2;
      ctx.stroke();

      // 有根树绘制箭头方向
      if (isRooted && selectedRoot !== null) {
        const parent = nodes[u].id === getParent(v) ? nodes[u] : nodes[v];
        const child = nodes[u].id === getParent(v) ? nodes[v] : nodes[u];
        // 简单的方向指示（不画箭头，用颜色区分）
      }
    }

    // 绘制节点
    for (let node of nodes) {
      ctx.beginPath();
      ctx.arc(node.x, node.y, 18, 0, 2 * Math.PI);

      let fill = '#3b82f6';
      if (node.id === selectedRoot) fill = '#f97316';
      else if (isRooted && isLeaf(node.id)) fill = '#10b981';

      ctx.fillStyle = fill;
      ctx.fill();
      ctx.strokeStyle = '#1f2937';
      ctx.lineWidth = 2;
      ctx.stroke();

      ctx.fillStyle = '#fff';
      ctx.font = 'bold 13px Arial';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(node.label, node.x, node.y);
    }

    // 标题
    ctx.fillStyle = '#374151';
    ctx.font = 'bold 13px Arial';
    ctx.textAlign = 'center';
    ctx.fillText(isRooted ? '有根树 (Rooted Tree)' : '无根树 (Unrooted Tree)', 200, 15);
  }

  function getParent(nodeId) {
    // 简化：从选中根开始BFS确定父子关系
    return null;
  }

  function isLeaf(nodeId) {
    if (!isRooted) return false;
    const children = edges.filter(e => {
      const parent = selectedRoot;
      // 简化判断
      return false;
    });
    return edges.filter(e => e.includes(nodeId)).length === 1 && nodeId !== selectedRoot;
  }

  canvas.addEventListener('click', (e) => {
    if (!selectMode) return;

    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX - rect.left) * (canvas.width / rect.width);
    const y = (e.clientY - rect.top) * (canvas.height / rect.height);

    for (let node of nodes) {
      if (Math.sqrt((x - node.x) ** 2 + (y - node.y) ** 2) < 20) {
        selectedRoot = node.id;
        document.getElementById('treeDefHint').textContent = `已选择节点 ${node.label} 作为根`;
        draw();
        break;
      }
    }
  });

  document.getElementById('toggleRootModeBtn').addEventListener('click', function() {
    selectMode = !selectMode;
    this.classList.toggle('active', selectMode);
    document.getElementById('treeDefHint').textContent = selectMode
      ? '点击树上任意节点作为根'
      : '点击"选择根节点"后，再点击树上任意节点作为根';
  });

  document.getElementById('convertBtn').addEventListener('click', () => {
    if (selectedRoot === null) {
      document.getElementById('treeDefHint').textContent = '请先选择一个根节点！';
      return;
    }
    isRooted = true;
    document.getElementById('treeDefHint').textContent = `已转换为以 ${nodes[selectedRoot].label} 为根的有根树`;
    draw();
  });

  document.getElementById('resetTreeBtn').addEventListener('click', () => {
    selectedRoot = null;
    isRooted = false;
    selectMode = false;
    document.getElementById('toggleRootModeBtn').classList.remove('active');
    document.getElementById('treeDefHint').textContent = '点击"选择根节点"后，再点击树上任意节点作为根';
    draw();
  });

  draw();
</script>