---
// 树的定义演示：无根树 vs 有根树（带物理动画）
---

<div class="tree-def-demo">
  <div class="demo-header">
    <span class="badge">交互演示</span>
    <span class="title">无根树 ⇄ 有根树</span>
  </div>
  <div class="demo-content">
    <canvas id="treeDefCanvas"></canvas>
    <div class="controls">
      <button class="btn" id="toggleRootModeBtn">选择根节点</button>
      <button class="btn primary" id="convertBtn">提起来！</button>
      <button class="btn danger" id="resetTreeBtn">重置</button>
    </div>
    <p class="hint" id="treeDefHint">点击"选择根节点"后，再点击树上任意节点作为根</p>
  </div>
</div>

<style>
  .tree-def-demo {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border-radius: 12px;
    padding: 1rem;
    margin: 1rem 0;
    border: 2px solid #f59e0b;
  }
  .tree-def-demo .demo-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 0.8rem;
  }
  .tree-def-demo .badge {
    background: #f59e0b;
    color: white;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .tree-def-demo .title {
    font-weight: 600;
    color: #92400e;
  }
  .tree-def-demo .demo-content {
    background: white;
    border-radius: 8px;
    padding: 12px;
  }
  .tree-def-demo canvas {
    display: block;
    margin: 0 auto;
    background: linear-gradient(180deg, #f0f9ff 0%, #e0f2fe 100%);
    border-radius: 6px;
    border: 1px solid #bae6fd;
  }
  .tree-def-demo .controls {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .tree-def-demo .btn {
    padding: 6px 14px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    background: #e5e7eb;
    color: #374151;
    transition: all 0.2s;
  }
  .tree-def-demo .btn:hover {
    background: #d1d5db;
  }
  .tree-def-demo .btn.primary {
    background: #f97316;
    color: white;
  }
  .tree-def-demo .btn.primary:hover {
    background: #ea580c;
  }
  .tree-def-demo .btn.danger {
    background: #ef4444;
    color: white;
  }
  .tree-def-demo .btn.danger:hover {
    background: #dc2626;
  }
  .tree-def-demo .btn.active {
    background: #3b82f6;
    color: white;
  }
  .tree-def-demo .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .tree-def-demo .hint {
    text-align: center;
    font-size: 0.8rem;
    color: #6b7280;
    margin: 8px 0 0 0;
  }
</style>

<script>
  const canvas = document.getElementById('treeDefCanvas');
  const ctx = canvas.getContext('2d');
  canvas.width = 500;
  canvas.height = 380;

  // 树结构定义
  const treeStructure = {
    0: [1, 2],
    1: [0, 3, 4],
    2: [0, 5, 6],
    3: [1, 7],
    4: [1],
    5: [2, 8],
    6: [2],
    7: [3],
    8: [5]
  };

  const nodeLabels = ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I'];

  // 物理模拟相关
  class PhysicsNode {
    constructor(id, x, y, label) {
      this.id = id;
      this.x = x;
      this.y = y;
      this.targetX = x;
      this.targetY = y;
      this.vx = 0;
      this.vy = 0;
      this.label = label;
      this.fixed = false;
      this.depth = 0;
      this.children = [];
    }

    update(gravity, damping) {
      if (this.fixed) return;

      const dx = this.targetX - this.x;
      const dy = this.targetY - this.y;

      this.vx += dx * 0.1;
      this.vy += dy * 0.1 + gravity;

      this.vx *= damping;
      this.vy *= damping;

      this.x += this.vx;
      this.y += this.vy;
    }
  }

  let nodes = [];
  let selectedRoot = null;
  let selectMode = false;
  let isAnimating = false;
  let animationId = null;

  // 初始化无根树布局
  function initUnrootedLayout() {
    nodes = [];
    const centerX = canvas.width / 2;
    const centerY = canvas.height / 2;
    const radius = 120;

    for (let i = 0; i < 9; i++) {
      const angle = (i * 40 - 90) * Math.PI / 180;
      const r = radius + (i % 2) * 40;
      const x = centerX + r * Math.cos(angle);
      const y = centerY + r * Math.sin(angle);
      nodes.push(new PhysicsNode(i, x, y, nodeLabels[i]));
    }
  }

  // 构建有根树结构并计算子树宽度
  function buildRootedTree(rootId) {
    const visited = new Set();

    function dfs(id, depth) {
      if (visited.has(id)) return { width: 0, children: [] };
      visited.add(id);

      nodes[id].depth = depth;

      const childIds = treeStructure[id].filter(nid => !visited.has(nid));
      let totalWidth = 0;
      const children = [];

      for (let cid of childIds) {
        const result = dfs(cid, depth + 1);
        children.push(cid);
        totalWidth += result.width;
      }

      // 叶子节点宽度为1，内部节点宽度为子树宽度之和
      const width = Math.max(1, totalWidth);

      nodes[id].children = children;

      return { width, children };
    }

    dfs(rootId, 0);
  }

  // 设置有根树的目标位置（基于子树宽度）
  function setRootedTargets(rootId) {
    buildRootedTree(rootId);

    const levelY = [35, 115, 195, 275, 355]; // 根节点在最顶层

    // 使用递归计算x位置
    function assignX(id, left, right) {
      const node = nodes[id];
      node.targetY = levelY[node.depth] || levelY[levelY.length - 1];
      node.targetX = (left + right) / 2;

      if (node.children.length === 0) return;

      // 计算每个子树的宽度比例
      const totalWidth = right - left;
      const childWidths = node.children.map(cid => {
        // 估算子树宽度
        return getSubtreeWidth(cid);
      });
      const totalChildWidth = childWidths.reduce((a, b) => a + b, 0);

      let currentLeft = left;
      for (let i = 0; i < node.children.length; i++) {
        const cid = node.children[i];
        const cw = (childWidths[i] / totalChildWidth) * totalWidth;
        assignX(cid, currentLeft, currentLeft + cw);
        currentLeft += cw;
      }
    }

    function getSubtreeWidth(id) {
      const node = nodes[id];
      if (node.children.length === 0) return 1;
      return node.children.reduce((sum, cid) => sum + getSubtreeWidth(cid), 0);
    }

    // 从根开始分配位置
    assignX(rootId, 50, canvas.width - 50);

    // 根节点固定
    nodes[rootId].fixed = true;
  }

  // 绘制函数
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // 绘制层级线（有根树模式）
    if (selectedRoot !== null) {
      const levelY = [35, 115, 195, 275];
      ctx.setLineDash([4, 4]);
      ctx.strokeStyle = '#e2e8f0';
      ctx.lineWidth = 1;
      for (let i = 1; i < levelY.length; i++) {
        ctx.beginPath();
        ctx.moveTo(30, levelY[i]);
        ctx.lineTo(canvas.width - 30, levelY[i]);
        ctx.stroke();
      }
      ctx.setLineDash([]);

      // 深度标签
      ctx.fillStyle = '#94a3b8';
      ctx.font = '10px Arial';
      ctx.textAlign = 'right';
      ctx.fillText('depth 0', 45, 31);
      ctx.fillText('depth 1', 45, 111);
      ctx.fillText('depth 2', 45, 191);
      ctx.fillText('depth 3', 45, 271);
    }

    // 绘制边
    for (let [id, neighbors] of Object.entries(treeStructure)) {
      const node = nodes[parseInt(id)];
      for (let nid of neighbors) {
        if (parseInt(id) < nid) {
          const neighbor = nodes[nid];

          // 边的颜色
          let edgeColor = '#cbd5e1';
          if (selectedRoot !== null) {
            edgeColor = '#fed7aa'; // 有根树模式下用暖色
          }

          ctx.beginPath();
          ctx.moveTo(node.x, node.y);
          ctx.lineTo(neighbor.x, neighbor.y);
          ctx.strokeStyle = edgeColor;
          ctx.lineWidth = 3;
          ctx.stroke();
        }
      }
    }

    // 绘制节点
    for (let node of nodes) {
      // 节点阴影
      ctx.beginPath();
      ctx.arc(node.x + 2, node.y + 2, 20, 0, 2 * Math.PI);
      ctx.fillStyle = 'rgba(0,0,0,0.1)';
      ctx.fill();

      // 节点本体
      ctx.beginPath();
      ctx.arc(node.x, node.y, 20, 0, 2 * Math.PI);

      let fill = '#3b82f6';
      if (node.id === selectedRoot) {
        fill = '#f97316';
      } else if (selectedRoot !== null) {
        // 叶子节点用绿色
        if (node.children.length === 0) {
          fill = '#10b981';
        } else {
          fill = '#60a5fa'; // 中间节点浅蓝
        }
      }

      ctx.fillStyle = fill;
      ctx.fill();
      ctx.strokeStyle = '#1f2937';
      ctx.lineWidth = 2;
      ctx.stroke();

      // 节点标签
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 14px Arial';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(node.label, node.x, node.y);
    }

    // 标题
    ctx.fillStyle = '#374151';
    ctx.font = 'bold 14px Arial';
    ctx.textAlign = 'center';
    ctx.fillText(selectedRoot !== null ? '有根树 (Rooted Tree)' : '无根树 (Unrooted Tree)', canvas.width / 2, 20);
  }

  // 动画循环
  function animate() {
    if (!isAnimating) return;

    let allSettled = true;

    for (let node of nodes) {
      node.update(0.4, 0.82);

      const dx = Math.abs(node.x - node.targetX);
      const dy = Math.abs(node.y - node.targetY);
      if (dx > 0.5 || dy > 0.5 || Math.abs(node.vx) > 0.1 || Math.abs(node.vy) > 0.1) {
        allSettled = false;
      }
    }

    draw();

    if (allSettled) {
      isAnimating = false;
      document.getElementById('convertBtn').disabled = false;
      document.getElementById('treeDefHint').textContent = '橙色=根节点，绿色=叶节点，蓝色=中间节点';
    } else {
      animationId = requestAnimationFrame(animate);
    }
  }

  // 开始动画
  function startLiftAnimation() {
    if (selectedRoot === null) {
      document.getElementById('treeDefHint').textContent = '请先选择一个根节点！';
      return;
    }

    isAnimating = true;
    document.getElementById('convertBtn').disabled = true;
    document.getElementById('treeDefHint').textContent = '正在提起...';

    setRootedTargets(selectedRoot);
    animate();
  }

  // 点击选择根节点
  canvas.addEventListener('click', (e) => {
    if (!selectMode || isAnimating) return;

    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX - rect.left) * (canvas.width / rect.width);
    const y = (e.clientY - rect.top) * (canvas.height / rect.height);

    for (let node of nodes) {
      if (Math.sqrt((x - node.x) ** 2 + (y - node.y) ** 2) < 22) {
        selectedRoot = node.id;
        document.getElementById('treeDefHint').textContent = `已选择节点 ${node.label} 作为根，点击"提起来！"`;
        draw();
        break;
      }
    }
  });

  // 按钮事件
  document.getElementById('toggleRootModeBtn').addEventListener('click', function() {
    if (isAnimating) return;
    selectMode = !selectMode;
    this.classList.toggle('active', selectMode);
    this.textContent = selectMode ? '取消选择' : '选择根节点';
    document.getElementById('treeDefHint').textContent = selectMode
      ? '点击树上任意节点作为根'
      : '点击"选择根节点"后，再点击树上任意节点作为根';
  });

  document.getElementById('convertBtn').addEventListener('click', startLiftAnimation);

  document.getElementById('resetTreeBtn').addEventListener('click', () => {
    if (animationId) cancelAnimationFrame(animationId);
    isAnimating = false;
    selectedRoot = null;
    selectMode = false;

    initUnrootedLayout();

    document.getElementById('toggleRootModeBtn').classList.remove('active');
    document.getElementById('toggleRootModeBtn').textContent = '选择根节点';
    document.getElementById('convertBtn').disabled = false;
    document.getElementById('treeDefHint').textContent = '点击"选择根节点"后，再点击树上任意节点作为根';
    draw();
  });

  // 初始化
  initUnrootedLayout();
  draw();
</script>