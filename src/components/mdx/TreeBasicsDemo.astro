---
// 树基础交互演示组件
---

<div class="tree-basics-demo">
  <div class="tabs">
    <button class="tab-btn active" data-tab="definition">树的定义</button>
    <button class="tab-btn" data-tab="terms">树的术语</button>
    <button class="tab-btn" data-tab="types">特殊树类型</button>
    <button class="tab-btn" data-tab="traversal">树遍历</button>
  </div>

  <div class="container">
    <!-- 定义面板 -->
    <div id="definition-panel" class="tab-content active">
      <div class="canvas-area">
        <canvas id="definitionCanvas"></canvas>
        <div class="legend">
          <div class="legend-item"><span class="dot info"></span> 普通节点</div>
          <div class="legend-item"><span class="dot warning"></span> 选中根节点</div>
        </div>
        <div class="controls">
          <button class="btn-primary" id="toggleRootBtn">切换根节点模式</button>
          <button class="btn-info" id="animateRootBtn">演示转有根树</button>
          <button class="btn-danger" id="resetDefBtn">重置</button>
        </div>
      </div>
      <div class="log-area">
        <div class="log-header">📋 说明</div>
        <div class="info-panel">
          <h3>无根树 vs 有根树</h3>
          <p><strong>无根树：</strong>没有固定的根节点，所有节点地位平等。</p>
          <p><strong>有根树：</strong>指定一个节点作为根，形成层级结构。</p>
          <p style="margin-top:10px;"><strong>操作提示：</strong></p>
          <p>• 点击节点选择作为根</p>
          <p>• 点击"演示转有根树"观看动画</p>
        </div>
        <ul id="definition-log" class="log-list">
          <li style="color:#888;">当前显示：无根树</li>
        </ul>
      </div>
    </div>

    <!-- 术语面板 -->
    <div id="terms-panel" class="tab-content">
      <div class="canvas-area">
        <canvas id="termsCanvas"></canvas>
        <div class="legend">
          <div class="legend-item"><span class="dot primary"></span> 根节点</div>
          <div class="legend-item"><span class="dot success"></span> 叶节点</div>
          <div class="legend-item"><span class="dot warning"></span> 高亮节点</div>
        </div>
        <div class="controls">
          <select id="termSelect">
            <option value="root">根节点 (Root)</option>
            <option value="leaf">叶节点 (Leaf)</option>
            <option value="parent">父节点 (Parent)</option>
            <option value="child">子节点 (Child)</option>
            <option value="sibling">兄弟节点 (Sibling)</option>
            <option value="ancestor">祖先 (Ancestor)</option>
            <option value="descendant">后代 (Descendant)</option>
            <option value="depth">深度 (Depth)</option>
            <option value="subtree">子树 (Subtree)</option>
          </select>
          <button class="btn-primary" id="animateTermBtn">动画演示</button>
        </div>
      </div>
      <div class="log-area">
        <div class="log-header">📖 术语解释</div>
        <div id="term-explanation" class="info-panel">
          <h3>根节点 (Root)</h3>
          <p>树的顶端节点，没有父节点。是整棵树的起点。</p>
        </div>
      </div>
    </div>

    <!-- 类型面板 -->
    <div id="types-panel" class="tab-content">
      <div class="canvas-area">
        <canvas id="typesCanvas"></canvas>
        <div class="controls">
          <button class="btn-primary" data-type="chain">链 (Chain)</button>
          <button class="btn-success" data-type="star">星形 (Star)</button>
          <button class="btn-info" data-type="full">完整二叉树</button>
          <button class="btn-warning" data-type="complete">完全二叉树</button>
          <button class="btn-danger" data-type="perfect">完美二叉树</button>
        </div>
      </div>
      <div class="log-area">
        <div class="log-header">📚 树类型说明</div>
        <div id="type-explanation" class="info-panel">
          <h3>选择一种树类型</h3>
          <p>点击左侧按钮查看不同类型的树结构。</p>
        </div>
      </div>
    </div>

    <!-- 遍历面板 -->
    <div id="traversal-panel" class="tab-content">
      <div class="canvas-area">
        <canvas id="traversalCanvas"></canvas>
        <div class="legend">
          <div class="legend-item"><span class="dot info"></span> 未访问</div>
          <div class="legend-item"><span class="dot warning"></span> 正在访问</div>
          <div class="legend-item"><span class="dot success"></span> 已访问</div>
        </div>
        <div class="controls">
          <select id="traversalType">
            <option value="preorder">先序遍历 (根→左→右)</option>
            <option value="inorder">中序遍历 (左→根→右)</option>
            <option value="postorder">后序遍历 (左→右→根)</option>
            <option value="bfs">层序遍历 (BFS)</option>
          </select>
          <button class="btn-primary" id="startTraversalBtn">开始遍历</button>
          <button class="btn-success" id="stepTraversalBtn">下一步</button>
          <button class="btn-danger" id="resetTraversalBtn">重置</button>
          <div class="speed-control">
            <label for="speedRange">速度:</label>
            <input type="range" id="speedRange" min="200" max="2000" value="800" />
          </div>
        </div>
      </div>
      <div class="log-area">
        <div class="log-header">📝 遍历序列</div>
        <ul id="traversal-log" class="log-list">
          <li style="color:#888;">点击"开始遍历"观看动画</li>
        </ul>
        <div class="info-panel" style="margin-top:10px;">
          <h3>遍历结果</h3>
          <p id="traversal-result">-</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .tree-basics-demo {
    margin: 1.5rem 0;
    background: #f8fafc;
    border-radius: 12px;
    padding: 1rem;
    border: 1px solid #e2e8f0;
  }

  .tree-basics-demo .tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tree-basics-demo .tab-btn {
    padding: 8px 16px;
    border: 2px solid #f97316;
    background: white;
    color: #f97316;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
    font-size: 0.85rem;
  }

  .tree-basics-demo .tab-btn:hover {
    background: #fff7ed;
  }

  .tree-basics-demo .tab-btn.active {
    background: #f97316;
    color: white;
  }

  .tree-basics-demo .container {
    display: flex;
    gap: 1rem;
    background: white;
    padding: 1rem;
    border-radius: 8px;
  }

  .tree-basics-demo .tab-content {
    display: none;
    width: 100%;
  }

  .tree-basics-demo .tab-content.active {
    display: flex;
    gap: 1rem;
  }

  .tree-basics-demo .canvas-area {
    flex: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tree-basics-demo canvas {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    max-width: 100%;
    height: auto;
  }

  .tree-basics-demo .controls {
    margin-top: 12px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
  }

  .tree-basics-demo button {
    padding: 6px 14px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
    font-size: 0.8rem;
  }

  .tree-basics-demo button:disabled {
    background-color: #ccc;
    cursor: not-allowed;
  }

  .tree-basics-demo .btn-primary { background-color: #f97316; color: white; }
  .tree-basics-demo .btn-primary:hover:not(:disabled) { background-color: #ea580c; }
  .tree-basics-demo .btn-success { background-color: #10b981; color: white; }
  .tree-basics-demo .btn-success:hover:not(:disabled) { background-color: #059669; }
  .tree-basics-demo .btn-info { background-color: #3b82f6; color: white; }
  .tree-basics-demo .btn-info:hover:not(:disabled) { background-color: #2563eb; }
  .tree-basics-demo .btn-warning { background-color: #f59e0b; color: white; }
  .tree-basics-demo .btn-warning:hover:not(:disabled) { background-color: #d97706; }
  .tree-basics-demo .btn-danger { background-color: #ef4444; color: white; }
  .tree-basics-demo .btn-danger:hover:not(:disabled) { background-color: #dc2626; }

  .tree-basics-demo .log-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 220px;
    max-width: 300px;
    padding-left: 1rem;
    border-left: 1px solid #e5e7eb;
  }

  .tree-basics-demo .log-header {
    font-weight: bold;
    margin-bottom: 8px;
    border-bottom: 2px solid #f97316;
    padding-bottom: 4px;
    font-size: 0.9rem;
  }

  .tree-basics-demo .log-list {
    flex: 1;
    overflow-y: auto;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 0.8rem;
    list-style: none;
    padding: 0;
    margin: 0;
    max-height: 200px;
  }

  .tree-basics-demo .log-list li {
    padding: 4px 8px;
    border-bottom: 1px solid #f3f4f6;
    line-height: 1.3;
  }

  .tree-basics-demo .info-panel {
    background: #f1f5f9;
    border-radius: 6px;
    padding: 10px;
    margin-top: 8px;
    font-size: 0.8rem;
  }

  .tree-basics-demo .info-panel h3 {
    margin: 0 0 6px 0;
    color: #f97316;
    font-size: 0.9rem;
  }

  .tree-basics-demo .info-panel p {
    margin: 3px 0;
    color: #475569;
  }

  .tree-basics-demo .legend {
    display: flex;
    gap: 12px;
    margin-top: 8px;
    font-size: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tree-basics-demo .legend-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .tree-basics-demo .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }

  .tree-basics-demo .dot.primary { background: #f97316; }
  .tree-basics-demo .dot.success { background: #10b981; }
  .tree-basics-demo .dot.warning { background: #f59e0b; }
  .tree-basics-demo .dot.info { background: #3b82f6; }

  .tree-basics-demo select {
    padding: 6px 10px;
    border: 2px solid #e5e7eb;
    border-radius: 6px;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .tree-basics-demo .speed-control {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.8rem;
  }

  .tree-basics-demo .speed-control input {
    width: 80px;
  }

  @media (max-width: 768px) {
    .tree-basics-demo .container {
      flex-direction: column;
    }
    .tree-basics-demo .tab-content.active {
      flex-direction: column;
    }
    .tree-basics-demo .log-area {
      border-left: none;
      border-top: 1px solid #e5e7eb;
      padding-left: 0;
      padding-top: 1rem;
      max-width: 100%;
    }
  }
</style>

<script>
  // ===================== 全局变量 =====================
  let currentTab = 'definition';

  // ===================== 标签切换 =====================
  document.querySelectorAll('.tree-basics-demo .tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;
      currentTab = tab;

      document.querySelectorAll('.tree-basics-demo .tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tree-basics-demo .tab-content').forEach(p => p.classList.remove('active'));

      btn.classList.add('active');
      document.getElementById(`${tab}-panel`).classList.add('active');

      if (tab === 'definition') initDefinition();
      else if (tab === 'terms') initTerms();
      else if (tab === 'types') initTypes();
      else if (tab === 'traversal') initTraversal();
    });
  });

  // ===================== 定义面板 =====================
  const defCanvas = document.getElementById('definitionCanvas');
  const defCtx = defCanvas.getContext('2d');

  let defNodes = [];
  let defEdges = [];
  let selectedRoot = null;
  let isRooted = false;
  let rootModeActive = false;

  function initDefinition() {
    defCanvas.width = 450;
    defCanvas.height = 320;

    defNodes = [
      { id: 0, x: 225, y: 50, label: 'A' },
      { id: 1, x: 120, y: 130, label: 'B' },
      { id: 2, x: 330, y: 130, label: 'C' },
      { id: 3, x: 60, y: 210, label: 'D' },
      { id: 4, x: 160, y: 210, label: 'E' },
      { id: 5, x: 270, y: 210, label: 'F' },
      { id: 6, x: 380, y: 210, label: 'G' },
      { id: 7, x: 60, y: 290, label: 'H' },
      { id: 8, x: 270, y: 290, label: 'I' },
    ];

    defEdges = [[0, 1], [0, 2], [1, 3], [1, 4], [2, 5], [2, 6], [3, 7], [5, 8]];

    selectedRoot = null;
    isRooted = false;
    rootModeActive = false;
    drawDefinition();
  }

  defCanvas.addEventListener('click', (e) => {
    if (!rootModeActive) return;

    const rect = defCanvas.getBoundingClientRect();
    const x = (e.clientX - rect.left) * (defCanvas.width / rect.width);
    const y = (e.clientY - rect.top) * (defCanvas.height / rect.height);

    for (let node of defNodes) {
      const dist = Math.sqrt((x - node.x) ** 2 + (y - node.y) ** 2);
      if (dist < 20) {
        selectedRoot = node.id;
        logDefinition(`选中节点 ${node.label} 作为根`);
        drawDefinition();
        break;
      }
    }
  });

  document.getElementById('toggleRootBtn').addEventListener('click', () => {
    rootModeActive = !rootModeActive;
    logDefinition(rootModeActive ? '根节点选择模式已开启' : '根节点选择模式已关闭');
  });

  document.getElementById('animateRootBtn').addEventListener('click', () => {
    if (selectedRoot === null) {
      logDefinition('请先选择一个根节点！');
      return;
    }
    isRooted = true;
    logDefinition(`转换为以 ${defNodes[selectedRoot].label} 为根的有根树`);
    drawDefinition();
  });

  document.getElementById('resetDefBtn').addEventListener('click', () => {
    initDefinition();
    document.getElementById('definition-log').innerHTML = '<li style="color:#888;">当前显示：无根树</li>';
  });

  function drawDefinition(flash = false) {
    defCtx.clearRect(0, 0, defCanvas.width, defCanvas.height);

    for (let [u, v] of defEdges) {
      defCtx.beginPath();
      defCtx.moveTo(defNodes[u].x, defNodes[u].y);
      defCtx.lineTo(defNodes[v].x, defNodes[v].y);
      defCtx.strokeStyle = '#ccc';
      defCtx.lineWidth = 2;
      defCtx.stroke();
    }

    for (let node of defNodes) {
      defCtx.beginPath();
      defCtx.arc(node.x, node.y, 20, 0, 2 * Math.PI);

      let fill = '#3b82f6';
      if (node.id === selectedRoot) fill = '#f97316';

      defCtx.fillStyle = fill;
      defCtx.fill();
      defCtx.strokeStyle = '#333';
      defCtx.lineWidth = 2;
      defCtx.stroke();

      defCtx.fillStyle = '#fff';
      defCtx.font = 'bold 14px Arial';
      defCtx.textAlign = 'center';
      defCtx.textBaseline = 'middle';
      defCtx.fillText(node.label, node.x, node.y);
    }

    defCtx.fillStyle = '#333';
    defCtx.font = 'bold 14px Arial';
    defCtx.textAlign = 'center';
    defCtx.fillText(isRooted ? '有根树' : '无根树', 225, 20);
  }

  function logDefinition(msg) {
    const log = document.getElementById('definition-log');
    const li = document.createElement('li');
    li.textContent = msg;
    log.appendChild(li);
    log.scrollTop = log.scrollHeight;
  }

  // ===================== 术语面板 =====================
  const termsCanvas = document.getElementById('termsCanvas');
  const termsCtx = termsCanvas.getContext('2d');

  let termsNodes = [];
  let termsEdges = [];

  const termExplanations = {
    root: { title: '根节点 (Root)', desc: '树的顶端节点，没有父节点。是整棵树的起点。', highlight: [0] },
    leaf: { title: '叶节点 (Leaf)', desc: '没有子节点的节点。位于树的末端。', highlight: [3, 4, 6, 7, 8] },
    parent: { title: '父节点 (Parent)', desc: '节点 B 是 D、E 的父节点。', highlight: [1] },
    child: { title: '子节点 (Child)', desc: '节点 D、E 是 B 的子节点。', highlight: [3, 4] },
    sibling: { title: '兄弟节点 (Sibling)', desc: '节点 D、E 是兄弟节点。', highlight: [3, 4] },
    ancestor: { title: '祖先 (Ancestor)', desc: '节点 H 的祖先是 A、B、D。', highlight: [0, 1, 3, 7] },
    descendant: { title: '后代 (Descendant)', desc: '节点 B 的后代是 D、E、H。', highlight: [1, 3, 4, 7] },
    depth: { title: '深度 (Depth)', desc: '节点 H 的深度是 3。', highlight: [0, 1, 3, 7] },
    subtree: { title: '子树 (Subtree)', desc: '以 B 为根的子树包含 B、D、E、H。', highlight: [1, 3, 4, 7] }
  };

  function initTerms() {
    termsCanvas.width = 450;
    termsCanvas.height = 320;

    termsNodes = [
      { id: 0, x: 225, y: 40, label: 'A', depth: 0 },
      { id: 1, x: 120, y: 110, label: 'B', depth: 1 },
      { id: 2, x: 330, y: 110, label: 'C', depth: 1 },
      { id: 3, x: 60, y: 180, label: 'D', depth: 2 },
      { id: 4, x: 160, y: 180, label: 'E', depth: 2 },
      { id: 5, x: 270, y: 180, label: 'F', depth: 2 },
      { id: 6, x: 380, y: 180, label: 'G', depth: 2 },
      { id: 7, x: 60, y: 250, label: 'H', depth: 3 },
      { id: 8, x: 270, y: 250, label: 'I', depth: 3 },
    ];

    termsEdges = [[0, 1], [0, 2], [1, 3], [1, 4], [2, 5], [2, 6], [3, 7], [5, 8]];

    highlightTerm();
  }

  document.getElementById('termSelect').addEventListener('change', highlightTerm);

  function highlightTerm() {
    const term = document.getElementById('termSelect').value;
    const info = termExplanations[term];

    document.getElementById('term-explanation').innerHTML = `
      <h3>${info.title}</h3>
      <p>${info.desc}</p>
    `;

    drawTerms(info.highlight);
  }

  document.getElementById('animateTermBtn').addEventListener('click', () => {
    const term = document.getElementById('termSelect').value;
    const info = termExplanations[term];

    let step = 0;
    const interval = setInterval(() => {
      const highlighted = info.highlight.slice(0, step + 1);
      drawTerms(highlighted);
      step++;
      if (step >= info.highlight.length) clearInterval(interval);
    }, 300);
  });

  function drawTerms(highlighted = []) {
    termsCtx.clearRect(0, 0, termsCanvas.width, termsCanvas.height);

    for (let [u, v] of termsEdges) {
      termsCtx.beginPath();
      termsCtx.moveTo(termsNodes[u].x, termsNodes[u].y);
      termsCtx.lineTo(termsNodes[v].x, termsNodes[v].y);
      termsCtx.strokeStyle = '#ddd';
      termsCtx.lineWidth = 2;
      termsCtx.stroke();
    }

    for (let node of termsNodes) {
      termsCtx.beginPath();
      termsCtx.arc(node.x, node.y, 18, 0, 2 * Math.PI);

      let fill = '#3b82f6';
      const children = termsEdges.filter(e => e[0] === node.id);

      if (highlighted.includes(node.id)) {
        fill = '#f97316';
      } else if (children.length === 0) {
        fill = '#10b981';
      } else if (node.id === 0) {
        fill = '#f97316';
      }

      termsCtx.fillStyle = fill;
      termsCtx.fill();
      termsCtx.strokeStyle = '#333';
      termsCtx.lineWidth = 2;
      termsCtx.stroke();

      termsCtx.fillStyle = '#fff';
      termsCtx.font = 'bold 13px Arial';
      termsCtx.textAlign = 'center';
      termsCtx.textBaseline = 'middle';
      termsCtx.fillText(node.label, node.x, node.y);
    }
  }

  // ===================== 类型面板 =====================
  const typesCanvas = document.getElementById('typesCanvas');
  const typesCtx = typesCanvas.getContext('2d');

  function initTypes() {
    typesCanvas.width = 450;
    typesCanvas.height = 320;
    showTreeType('chain');
  }

  document.querySelectorAll('.tree-basics-demo [data-type]').forEach(btn => {
    btn.addEventListener('click', () => showTreeType(btn.dataset.type));
  });

  function showTreeType(type) {
    typesCtx.clearRect(0, 0, typesCanvas.width, typesCanvas.height);

    let nodes = [];
    let edges = [];
    let title = '';
    let explanation = '';

    switch (type) {
      case 'chain':
        title = '链 (Chain)';
        explanation = '所有节点度数不超过 2。最"瘦长"的树结构。';
        for (let i = 0; i < 7; i++) {
          nodes.push({ x: 50 + i * 55, y: 160, label: String(i + 1) });
          if (i > 0) edges.push([i - 1, i]);
        }
        break;

      case 'star':
        title = '星形 (Star)';
        explanation = '一个中心节点，其余节点只与中心相连。';
        nodes.push({ x: 225, y: 160, label: 'C' });
        for (let i = 0; i < 6; i++) {
          const angle = (i * 60 - 90) * Math.PI / 180;
          nodes.push({ x: 225 + 90 * Math.cos(angle), y: 160 + 90 * Math.sin(angle), label: String.fromCharCode(65 + i) });
          edges.push([0, i + 1]);
        }
        break;

      case 'full':
        title = '完整二叉树';
        explanation = '每个节点有 0 或 2 个子节点。';
        nodes = [
          { x: 225, y: 60, label: '1' },
          { x: 140, y: 140, label: '2' },
          { x: 310, y: 140, label: '3' },
          { x: 90, y: 220, label: '4' },
          { x: 180, y: 220, label: '5' },
        ];
        edges = [[0, 1], [0, 2], [1, 3], [1, 4]];
        break;

      case 'complete':
        title = '完全二叉树';
        explanation = '除最后一层外全满，最后一层靠左。';
        nodes = [
          { x: 225, y: 40, label: '1' },
          { x: 140, y: 110, label: '2' },
          { x: 310, y: 110, label: '3' },
          { x: 90, y: 180, label: '4' },
          { x: 180, y: 180, label: '5' },
          { x: 270, y: 180, label: '6' },
          { x: 90, y: 250, label: '7' },
          { x: 180, y: 250, label: '8' },
        ];
        edges = [[0, 1], [0, 2], [1, 3], [1, 4], [2, 5], [3, 6], [4, 7]];
        break;

      case 'perfect':
        title = '完美二叉树';
        explanation = '所有叶节点深度相同，非叶节点都有两个子节点。';
        nodes = [
          { x: 225, y: 30, label: '1' },
          { x: 140, y: 90, label: '2' },
          { x: 310, y: 90, label: '3' },
          { x: 90, y: 150, label: '4' },
          { x: 180, y: 150, label: '5' },
          { x: 270, y: 150, label: '6' },
          { x: 360, y: 150, label: '7' },
          { x: 60, y: 210, label: '8' },
          { x: 115, y: 210, label: '9' },
          { x: 155, y: 210, label: '10' },
          { x: 205, y: 210, label: '11' },
          { x: 245, y: 210, label: '12' },
          { x: 295, y: 210, label: '13' },
          { x: 345, y: 210, label: '14' },
          { x: 395, y: 210, label: '15' },
        ];
        edges = [
          [0, 1], [0, 2], [1, 3], [1, 4], [2, 5], [2, 6],
          [3, 7], [3, 8], [4, 9], [4, 10], [5, 11], [5, 12], [6, 13], [6, 14]
        ];
        break;
    }

    typesCtx.fillStyle = '#333';
    typesCtx.font = 'bold 16px Arial';
    typesCtx.textAlign = 'center';
    typesCtx.fillText(title, 225, 20);

    for (let [u, v] of edges) {
      typesCtx.beginPath();
      typesCtx.moveTo(nodes[u].x, nodes[u].y);
      typesCtx.lineTo(nodes[v].x, nodes[v].y);
      typesCtx.strokeStyle = '#ccc';
      typesCtx.lineWidth = 2;
      typesCtx.stroke();
    }

    for (let node of nodes) {
      typesCtx.beginPath();
      typesCtx.arc(node.x, node.y, 16, 0, 2 * Math.PI);
      typesCtx.fillStyle = '#f97316';
      typesCtx.fill();
      typesCtx.strokeStyle = '#333';
      typesCtx.lineWidth = 2;
      typesCtx.stroke();

      typesCtx.fillStyle = '#fff';
      typesCtx.font = 'bold 11px Arial';
      typesCtx.textAlign = 'center';
      typesCtx.textBaseline = 'middle';
      typesCtx.fillText(node.label, node.x, node.y);
    }

    document.getElementById('type-explanation').innerHTML = `
      <h3>${title}</h3>
      <p>${explanation}</p>
    `;
  }

  // ===================== 遍历面板 =====================
  const travCanvas = document.getElementById('traversalCanvas');
  const travCtx = travCanvas.getContext('2d');

  let travNodes = [];
  let travEdges = [];
  let visited = [];
  let visitOrder = [];
  let traversalGenerator = null;
  let isAutoPlaying = false;
  let autoPlayTimer = null;
  let currentNode = null;

  function initTraversal() {
    travCanvas.width = 450;
    travCanvas.height = 320;

    travNodes = [
      { id: 0, x: 225, y: 40, label: 'A', left: 1, right: 2 },
      { id: 1, x: 120, y: 110, label: 'B', left: 3, right: 4 },
      { id: 2, x: 330, y: 110, label: 'C', left: 5, right: 6 },
      { id: 3, x: 60, y: 180, label: 'D', left: 7, right: null },
      { id: 4, x: 160, y: 180, label: 'E', left: null, right: null },
      { id: 5, x: 270, y: 180, label: 'F', left: 8, right: null },
      { id: 6, x: 380, y: 180, label: 'G', left: null, right: null },
      { id: 7, x: 60, y: 250, label: 'H', left: null, right: null },
      { id: 8, x: 270, y: 250, label: 'I', left: null, right: null },
    ];

    travEdges = [[0, 1], [0, 2], [1, 3], [1, 4], [2, 5], [2, 6], [3, 7], [5, 8]];

    visited = new Array(travNodes.length).fill(false);
    visitOrder = [];
    currentNode = null;

    drawTraversal();
  }

  function* preorderTraversal(nodeId) {
    if (nodeId === null || nodeId === undefined) return;

    yield { type: 'visit', nodeId };
    visited[nodeId] = true;
    visitOrder.push(travNodes[nodeId].label);
    logTraversal(`访问 ${travNodes[nodeId].label}`);
    updateResult();

    yield* preorderTraversal(travNodes[nodeId].left);
    yield* preorderTraversal(travNodes[nodeId].right);
  }

  function* inorderTraversal(nodeId) {
    if (nodeId === null || nodeId === undefined) return;

    yield* inorderTraversal(travNodes[nodeId].left);

    yield { type: 'visit', nodeId };
    visited[nodeId] = true;
    visitOrder.push(travNodes[nodeId].label);
    logTraversal(`访问 ${travNodes[nodeId].label}`);
    updateResult();

    yield* inorderTraversal(travNodes[nodeId].right);
  }

  function* postorderTraversal(nodeId) {
    if (nodeId === null || nodeId === undefined) return;

    yield* postorderTraversal(travNodes[nodeId].left);
    yield* postorderTraversal(travNodes[nodeId].right);

    yield { type: 'visit', nodeId };
    visited[nodeId] = true;
    visitOrder.push(travNodes[nodeId].label);
    logTraversal(`访问 ${travNodes[nodeId].label}`);
    updateResult();
  }

  function* bfsTraversal() {
    const queue = [0];
    const visitedSet = new Set();

    while (queue.length > 0) {
      const nodeId = queue.shift();
      if (visitedSet.has(nodeId)) continue;

      yield { type: 'visit', nodeId };
      visited[nodeId] = true;
      visitedSet.add(nodeId);
      visitOrder.push(travNodes[nodeId].label);
      logTraversal(`访问 ${travNodes[nodeId].label}`);
      updateResult();

      const node = travNodes[nodeId];
      if (node.left !== null && node.left !== undefined) queue.push(node.left);
      if (node.right !== null && node.right !== undefined) queue.push(node.right);
    }
  }

  document.getElementById('startTraversalBtn').addEventListener('click', () => {
    const type = document.getElementById('traversalType').value;

    visited = new Array(travNodes.length).fill(false);
    visitOrder = [];
    currentNode = null;
    document.getElementById('traversal-log').innerHTML = '';
    document.getElementById('traversal-result').textContent = '-';

    switch (type) {
      case 'preorder':
        traversalGenerator = preorderTraversal(0);
        logTraversal('开始先序遍历');
        break;
      case 'inorder':
        traversalGenerator = inorderTraversal(0);
        logTraversal('开始中序遍历');
        break;
      case 'postorder':
        traversalGenerator = postorderTraversal(0);
        logTraversal('开始后序遍历');
        break;
      case 'bfs':
        traversalGenerator = bfsTraversal();
        logTraversal('开始层序遍历');
        break;
    }

    isAutoPlaying = true;
    stepTraversal();
  });

  function stepTraversal() {
    if (!traversalGenerator) return;

    const result = traversalGenerator.next();

    if (result.done) {
      isAutoPlaying = false;
      if (autoPlayTimer) clearTimeout(autoPlayTimer);
      logTraversal('遍历完成！');
      return;
    }

    if (result.value) {
      currentNode = result.value.nodeId;
      drawTraversal();
    }

    if (isAutoPlaying) {
      const speed = 2200 - document.getElementById('speedRange').value;
      autoPlayTimer = setTimeout(stepTraversal, speed);
    }
  }

  document.getElementById('stepTraversalBtn').addEventListener('click', () => {
    if (!traversalGenerator) {
      document.getElementById('startTraversalBtn').click();
      return;
    }
    isAutoPlaying = false;
    if (autoPlayTimer) clearTimeout(autoPlayTimer);
    stepTraversal();
  });

  document.getElementById('resetTraversalBtn').addEventListener('click', () => {
    isAutoPlaying = false;
    if (autoPlayTimer) clearTimeout(autoPlayTimer);
    traversalGenerator = null;

    visited = new Array(travNodes.length).fill(false);
    visitOrder = [];
    currentNode = null;

    document.getElementById('traversal-log').innerHTML = '<li style="color:#888;">点击"开始遍历"观看动画</li>';
    document.getElementById('traversal-result').textContent = '-';

    drawTraversal();
  });

  function drawTraversal() {
    travCtx.clearRect(0, 0, travCanvas.width, travCanvas.height);

    for (let [u, v] of travEdges) {
      travCtx.beginPath();
      travCtx.moveTo(travNodes[u].x, travNodes[u].y);
      travCtx.lineTo(travNodes[v].x, travNodes[v].y);

      if (visited[u] && visited[v]) {
        travCtx.strokeStyle = '#10b981';
        travCtx.lineWidth = 3;
      } else {
        travCtx.strokeStyle = '#ddd';
        travCtx.lineWidth = 2;
      }
      travCtx.stroke();
    }

    for (let node of travNodes) {
      travCtx.beginPath();
      travCtx.arc(node.x, node.y, 18, 0, 2 * Math.PI);

      let fill = '#3b82f6';
      if (visited[node.id]) fill = '#10b981';
      if (node.id === currentNode) fill = '#f59e0b';

      travCtx.fillStyle = fill;
      travCtx.fill();
      travCtx.strokeStyle = '#333';
      travCtx.lineWidth = 2;
      travCtx.stroke();

      travCtx.fillStyle = '#fff';
      travCtx.font = 'bold 13px Arial';
      travCtx.textAlign = 'center';
      travCtx.textBaseline = 'middle';
      travCtx.fillText(node.label, node.x, node.y);
    }
  }

  function logTraversal(msg) {
    const log = document.getElementById('traversal-log');
    const li = document.createElement('li');
    li.textContent = msg;
    log.appendChild(li);
    log.scrollTop = log.scrollHeight;
  }

  function updateResult() {
    document.getElementById('traversal-result').textContent = visitOrder.join(' → ');
  }

  // 初始化
  initDefinition();
</script>