---
import type { CardProps } from "@interfaces/data";

interface Props extends CardProps {
  title?: string;
}

const { class: className = "", title = "~/content.md" } = Astro.props;
---

<div class={`bg-base-100 border border-base-300 rounded-md shadow-none w-full ${className} overflow-hidden`}>
  <div class="flex items-center gap-2 px-3 py-2 bg-base-200 border-b border-base-300">
    <div class="flex gap-1.5">
      <div class="w-3 h-3 rounded-full bg-[#FF5F56] border border-[#E0443E]"></div>
      <div class="w-3 h-3 rounded-full bg-[#FFBD2E] border border-[#DEA123]"></div>
      <div class="w-3 h-3 rounded-full bg-[#27C93F] border border-[#1AAB29]"></div>
    </div>
    <div class="ml-auto mr-auto text-xs font-mono text-base-content/60 select-none opacity-70">
      {title}
    </div>
  </div>
  <div class="bg-base-100">
    <slot />
  </div>
</div>
